{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/fetch-region",
      "destination": "/api/fetch-region.js"
    },
    {
      "source": "/assets/:region/:type/:filename",
      "destination": "/api/fetch-region.js"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}
