{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/app.js",
      "status": 403,
      "destination": "/index.html"
    },
    {
      "source": "/styles.css",
      "status": 403,
      "destination": "/index.html"
    },
    {
      "source": "/api/fetch-region",
      "destination": "/api/fetch-region.js"
    },
    {
      "source": "/assets/:region/:filename",
      "destination": "/api/fetch-region.js"
    },
    {
      "source": "/(ind|br|na|sac|mea|vn|bd|pk|sg|id|cis|th|tw|eu)",
      "destination": "/index.html"
    },
    {
      "source": "/(ind|br|na|sac|mea|vn|bd|pk|sg|id|cis|th|tw|eu)/",
      "destination": "/index.html"
    }
  ]
}
